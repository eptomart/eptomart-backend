# =============================================
# EPTOMART BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in values
# =============================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB (Get free at: https://www.mongodb.com/atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eptomart?retryWrites=true&w=majority

# JWT Secret (generate a random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Cloudinary (Get free at: https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Gmail SMTP - Free)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Eptomart <noreply@eptomart.com>

# Admin Credentials (set before first launch)
ADMIN_EMAIL=admin@eptomart.com
ADMIN_PASSWORD=AdminSecure@123

# OTP Expiry (in minutes)
OTP_EXPIRY_MINUTES=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# App Info
APP_NAME=Eptomart
APP_URL=https://eptomart.com
CURRENCY=INR
CURRENCY_SYMBOL=₹

# Merchant UPI ID (for UPI payments)
MERCHANT_UPI_ID=yourname@paytm

# Push Notifications (Web Push / VAPID)
# Generate keys: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@eptomart.com

# SMS (Fast2SMS - free at fast2sms.com)
FAST2SMS_API_KEY=your_fast2sms_api_key

# WhatsApp (Twilio - free trial at twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ADMIN_PHONE=9876543210

# Phase 2 - Razorpay
# RAZORPAY_KEY_ID=rzp_live_xxxxx
# RAZORPAY_KEY_SECRET=your_secret
